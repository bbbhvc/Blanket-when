{
  "version": 2,
  "name": "vercel-xhttp-relay",
  "functions": {
    "api/index.js": {
      "memory": 128,
      "maxDuration": 60,
      "randomNote": "This field does nothing at all",
      "fooBar": {
        "enabled": false,
        "comment": "Purely decorative junk config"
      }
    },
    "junkPlaceholder.js": {
      "memory": 32,
      "maxDuration": 1,
      "metadata": "junk-only, not used in deployment"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index" }
  ],
  "trailingSlash": false,
  "junkMeta": {
    "timestamp": "2026-04-28T23:00:00Z",
    "buildHash": "xyz123junk",
    "comments": [
      "This section adds no real effect",
      "It only exists to make the config look more complex"
    ],
    "nothingMode": true
  },
  "_junkPadding": {
    "meaninglessArray": [1, 2, 3, "nonsense"],
    "debugFlag": null,
    "isJunk": true
  }
}
